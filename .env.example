# .env.example
# Environment variables for aetherOS AI integration
# Copy this file to .env and fill in values for local AI features

# Ollama API (for local inference)
# OLLAMA_API_URL="http://localhost:11434"

# OpenAI-compatible API (alternative)
# OPENAI_API_KEY=""

# Anthropic API (for Claude integration)
# ANTHROPIC_API_KEY=""

# Not used in v0.1.0-demo.1
# Features work offline without these